SERVER_TYPE=http
SERVER_PORT=8080

AUTHENTICATION_API_KEY=PsicoMedixSecretWebhookToken2026!#

# Habilitar el Webhook Global de la API
WEBHOOK_GLOBAL_ENABLED=true

# 1. Cambia el puerto al puerto HTTPS de tu API de .NET y usa https://
WEBHOOK_GLOBAL_URL=https://host.docker.internal:7241/api/webhooks/whatsapp

# Dile a Evolution que use tu contraseña secreta como su APIKEY de salida
WEBHOOK_GLOBAL_WEBHOOK_BY_EVENTS=true

# Definir qué eventos queremos que nos envíe
WEBHOOK_EVENTS_MESSAGES_UPSERT=true

DATABASE_ENABLED=true
DATABASE_PROVIDER=postgresql
# Sincronizado con el nuevo nombre del servicio en el docker-compose
DATABASE_CONNECTION_URI=postgresql://evolution:evolution123@psicomedix-postgres:5432/evolution?schema=public
DATABASE_CONNECTION_CLIENT_NAME=evolution

# Desactivamos Redis para usar la RAM local y evitar colisiones
CACHE_REDIS_ENABLED=false
CACHE_LOCAL_ENABLED=true

CONFIG_SESSION_PHONE_CLIENT=Chrome
CONFIG_SESSION_PHONE_NAME=Chrome

CONFIG_SESSION_PHONE_VERSION=2.3000.1033773198
WEB_VERSION=2.3000.1033773198

DATABASE_SAVE_DATA_CHATS=true
DATABASE_SAVE_DATA_CONTACTS=true
DATABASE_SAVE_DATA_HISTORIC=false
DATABASE_SAVE_DATA_LABELS=false

# 2. AÑADE ESTA LÍNEA AL FINAL DE TU .ENV (Crucial para desarrollo local)
# Le dice a Node.js que no rechace el certificado de desarrollo de tu Visual Studio / .NET
NODE_TLS_REJECT_UNAUTHORIZED=0