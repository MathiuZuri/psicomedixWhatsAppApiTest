<MudDialog ActionsClass="px-6 pb-4">
    <DialogContent>
        <div class="appointment-dialog-header-luxury">
            <div class="avatar-glow-shell">
                <MudAvatar Color="Color.Primary" Size="Size.Large" Class="avatar-appointment-shadow">@Iniciales</MudAvatar>
            </div>
            <div class="appointment-header-text">
                <MudText Typo="Typo.h2" Class="appointment-dialog-code">Ticket: @Cita.CodigoCita</MudText>
                <div class="appointment-service-tag d-flex align-center gap-1 mt-1">
                    <MudIcon Icon="@Icons.Material.Filled.Bookmark" Size="Size.Small" Color="Color.Tertiary" />
                    <MudText Typo="Typo.caption" Class="fw-bold text-tertiary">@Cita.ServicioNombre</MudText>
                </div>
            </div>
        </div>

        <MudDivider Class="my-5" />

        <MudGrid Class="info-cards-grid">
            <MudItem xs="12" sm="6" Class="info-cell">
                <div class="info-card-box border-left-primary">
                    <span class="info-card-label">Paciente</span>
                    <span class="info-card-value font-semibold">@Cita.PacienteNombre</span>
                </div>
            </MudItem>
            
            <MudItem xs="12" sm="6" Class="info-cell">
                <div class="info-card-box border-left-secondary">
                    <span class="info-card-label">Médico Especialista</span>
                    <span class="info-card-value">@Cita.DoctorNombre</span>
                </div>
            </MudItem>

            <MudItem xs="12" sm="6" Class="info-cell">
                <div class="info-card-box">
                    <span class="info-card-label">Fecha Asignada</span>
                    <span class="info-card-value">@Cita.Fecha.ToString("dd / MM / yyyy")</span>
                </div>
            </MudItem>

            <MudItem xs="12" sm="6" Class="info-cell">
                <div class="info-card-box">
                    <span class="info-card-label">Bloque Horario</span>
                    <span class="info-card-value font-mono">@Cita.HoraInicio.ToString("hh\\:mm") - @Cita.HoraFin.ToString("hh\\:mm")</span>
                </div>
            </MudItem>

            <MudItem xs="12" Class="info-cell">
                <div class="info-card-box">
                    <span class="info-card-label">Motivo de la Consulta</span>
                    <span class="info-card-value text-sm">@Cita.Motivo</span>
                </div>
            </MudItem>

            <MudItem xs="12" Class="info-cell">
                <div class="info-card-box">
                    <span class="info-card-label">Observaciones de Admisión</span>
                    <span class="info-card-value text-sm text-secondary">@(string.IsNullOrWhiteSpace(Cita.Observaciones) ? "Sin anotaciones complementarias" : Cita.Observaciones)</span>
                </div>
            </MudItem>

            <MudItem xs="12" sm="6" Class="info-cell">
                <div class="info-card-box bg-transparent-border">
                    <span class="info-card-label">Estado de Control</span>
                    <div class="mt-1">
                        <MudChip T="string" Size="Size.Small" Color="@ObtenerColorEstado(Cita.Estado)" Variant="Variant.Filled" Class="fw-bold rounded-sm">
                            @Cita.Estado
                        </MudChip>
                    </div>
                </div>
            </MudItem>

            <MudItem xs="12" sm="6" Class="info-cell">
                <div class="info-card-box bg-transparent-border">
                    <span class="info-card-label">Fecha de Registro</span>
                    <span class="info-card-value text-xs text-muted mt-2">@Cita.FechaRegistro.ToString("dd/MM/yyyy HH:mm")</span>
                </div>
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Default" OnClick="Cerrar" Class="text-none px-5 rounded-lg shadow-none">Cerrar Ficha</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public CitaResponseDto Cita { get; set; } = new();

    private string Iniciales => string.IsNullOrWhiteSpace(Cita.PacienteNombre)
        ? "C"
        : string.Concat(Cita.PacienteNombre.Split(' ', StringSplitOptions.RemoveEmptyEntries).Select(p => p[0])).ToUpper();

    private void Cerrar() => MudDialog.Close();

    private static Color ObtenerColorEstado(EstadoCita estado) =>
        estado switch
        {
            EstadoCita.Pendiente => Color.Info,
            EstadoCita.Confirmada => Color.Success,
            EstadoCita.Reprogramada => Color.Warning,
            EstadoCita.Cancelada => Color.Error,
            EstadoCita.Atendida => Color.Success,
            EstadoCita.NoAsistio => Color.Dark,
            EstadoCita.Eliminada => Color.Error,
            _ => Color.Default
        };
}