<MudDialog ActionsClass="px-6 pb-4">
    <DialogContent>
        @* Perfil de Cuenta Estilo Credencial Premium *@
        <div class="user-dialog-header-luxury">
            <div class="avatar-glow-shell">
                <MudAvatar Color="Color.Primary" Size="Size.Large" Class="avatar-user-shadow">@Iniciales</MudAvatar>
            </div>
            <div class="user-header-text-block">
                <MudText Typo="Typo.h2" Class="user-dialog-name">@Usuario.NombreCompleto</MudText>
                <div class="user-subtags d-flex align-center gap-2 mt-1">
                    <MudIcon Icon="@Icons.Material.Filled.Badge" Size="Size.Small" Color="Color.Secondary" />
                    <MudText Typo="Typo.caption" Class="fw-bold font-mono text-secondary">
                        ID CUENTA: @Usuario.CodigoUsuario
                    </MudText>
                </div>
            </div>
        </div>

        <MudDivider Class="my-5" />

        @* Celdas de Control de Seguridad y Accesos *@
        <MudGrid Class="info-cards-grid">
            <MudItem xs="12" sm="6" Class="info-cell">
                <div class="user-info-box border-left-primary">
                    <span class="user-box-label">Nombre de Usuario (Alias)</span>
                    <span class="user-box-value font-mono truncate-text">@Usuario.UserName</span>
                </div>
            </MudItem>
            
            <MudItem xs="12" sm="6" Class="info-cell">
                <div class="user-info-box border-left-secondary">
                    <span class="user-box-label">Correo de Autenticación</span>
                    <span class="user-box-value truncate-text">@Usuario.Correo</span>
                </div>
            </MudItem>

            <MudItem xs="12" sm="6" Class="info-cell">
                <div class="user-info-box">
                    <span class="user-box-label">Fecha de Alta</span>
                    <span class="user-box-value">@Usuario.FechaRegistro.ToString("dd/MM/yyyy HH:mm")</span>
                </div>
            </MudItem>

            <MudItem xs="12" sm="6" Class="info-cell">
                <div class="user-info-box">
                    <span class="user-box-label">Último Acceso Registrado</span>
                    <span class="user-box-value font-mono">@(Usuario.UltimoAcceso.HasValue ? Usuario.UltimoAcceso.Value.ToString("dd/MM/yyyy HH:mm") : "Sin ingresos")</span>
                </div>
            </MudItem>

            <MudItem xs="12" Class="info-cell">
                <div class="user-info-box bg-dashed-cell">
                    <span class="user-box-label">Estado de Cuenta</span>
                    <div class="mt-1">
                        <MudChip T="string" Size="Size.Small" Color="@ObtenerColorEstado(Usuario.Estado)" Variant="Variant.Filled" Class="fw-bold table-chip-rounded">
                            @Usuario.Estado
                        </MudChip>
                    </div>
                </div>
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Default" OnClick="Cerrar" Class="text-none px-5 rounded-lg shadow-none">
            Cerrar Ficha
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public UsuarioResponseDto Usuario { get; set; } = new();

    private string Iniciales => string.IsNullOrWhiteSpace(Usuario.NombreCompleto)
        ? "U"
        : string.Concat(Usuario.NombreCompleto.Split(' ', StringSplitOptions.RemoveEmptyEntries).Select(p => p[0])).ToUpper();

    private void Cerrar() => MudDialog.Close();

    private static Color ObtenerColorEstado(EstadoUsuario estado) =>
        estado switch
        {
            EstadoUsuario.Activo => Color.Success,
            EstadoUsuario.Inactivo => Color.Warning,
            EstadoUsuario.Bloqueado => Color.Error,
            EstadoUsuario.Eliminado => Color.Error,
            _ => Color.Default
        };
}