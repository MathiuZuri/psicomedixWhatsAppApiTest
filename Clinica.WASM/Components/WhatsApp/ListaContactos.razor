<div class="sidebar-chat-luxury">
    @* Barra de búsqueda superior *@
    <div class="search-bar-container">
        <MudTextField @bind-Value="FiltroBusqueda"
                      Placeholder="Buscar o empezar un chat..."
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      IconSize="Size.Small"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Immediate="true"
                      Class="search-field-luxury" />
    </div>

    @* Lista de conversaciones con scroll propio *@
    <div class="contacts-scroll-area">
        <MudList T="ChatResponseDto" Clickable="true" SelectedValue="ChatSeleccionado" SelectedValueChanged="SeleccionarChat">
            @foreach (var chat in ChatsFiltrados)
            {
                <MudListItem Value="chat" Class="@(ChatSeleccionadoId == chat.Id ? "chat-item-active" : "chat-item-inactive")">
                    <div class="chat-row-layout">
                        @* Avatar con iniciales *@
                        <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Medium" Class="avatar-glow-luxury">
                            @chat.NombreContacto.Substring(0, Math.Min(2, chat.NombreContacto.Length)).ToUpper()
                        </MudAvatar>

                        @* Información de texto *@
                        <div class="chat-info-stack">
                            <div class="chat-info-top">
                                <MudText Typo="Typo.subtitle2" Class="contact-name-luxury">@chat.NombreContacto</MudText>
                                <MudText Typo="Typo.caption" Class="time-stamp-luxury">@chat.FechaUltimaInteraccion.ToLocalTime().ToString("HH:mm")</MudText>
                            </div>
                            <div class="chat-info-bottom">
                                <MudText Typo="Typo.body2" Class="preview-message-luxury">@chat.UltimoMensaje</MudText>
                                @if (chat.MensajesNoLeidos > 0)
                                {
                                    <span class="badge-unread-luxury">@chat.MensajesNoLeidos</span>
                                }
                            </div>
                        </div>
                    </div>
                </MudListItem>
            }
        </MudList>
    </div>
</div>