@if (Estados == null || !Estados.Any()) return;

<div class="finance-list-layer animate-scale-in">
    <div class="finance-layer-header-bar border-top-secondary">
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.MoneyOff" Color="Color.Secondary" />
            <MudText Typo="Typo.h3" Class="finance-layer-title">Cuentas por Cobrar y Deudas por Atención</MudText>
        </div>
        <MudText Typo="Typo.caption" Class="text-rose-gold font-mono fw-semibold">SALDOS PENDIENTES REALES</MudText>
    </div>

    <div class="overflow-x-auto-clean">
        <MudTable Items="Estados" Dense="false" Hover="true" Striped="true" Elevation="0" Class="luxury-finance-table">
            <HeaderContent>
                <MudTh Class="header-cell-premium">Paciente Acreditado</MudTh>
                <MudTh Class="header-cell-premium">Servicio Prestado</MudTh>
                <MudTh Class="header-cell-premium text-end">Costo Total</MudTh>
                <MudTh Class="header-cell-premium text-end">Monto Cubierto</MudTh>
                <MudTh Class="header-cell-premium text-end">Pasivo / Deuda Real</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Paciente" Class="fw-bold text-primary-dark">@context.Paciente</MudTd>
                <MudTd DataLabel="Servicio" Class="fw-medium">@context.Servicio</MudTd>
                <MudTd DataLabel="Total" Class="font-mono text-end">@context.MontoTotal.ToString("C")</MudTd>
                <MudTd DataLabel="Pagado" Class="font-mono text-success-dark fw-medium text-end">@context.TotalPagado.ToString("C")</MudTd>
                <MudTd DataLabel="Deuda" Class="font-mono text-rose-gold fw-bold text-end">@context.SaldoReal.ToString("C")</MudTd>
            </RowTemplate>
        </MudTable>
    </div>
</div>

@code {
    [Parameter] public List<EstadoPagoAtencionDto>? Estados { get; set; }
}