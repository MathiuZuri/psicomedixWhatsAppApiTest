<div class="loading-canvas-layer animate-fade-loop">
    <div class="spinner-tridimensional-shell">
        <MudProgressCircular Color="@Color"
                             Size="@Size"
                             Indeterminate="true" />
    </div>

    @if (!string.IsNullOrWhiteSpace(Message))
    {
        <MudText Typo="Typo.body2" Class="loading-sync-text mt-4">
            @Message
        </MudText>
    }
</div>

@code {
    [Parameter] public string Message { get; set; } = "Cargando información...";
    [Parameter] public Color Color { get; set; } = Color.Primary;
    [Parameter] public Size Size { get; set; } = Size.Medium;
}