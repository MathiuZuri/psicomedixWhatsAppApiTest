<MudDialog ActionsClass="px-6 pb-4">
    <DialogContent>
        @* Encabezado de Ficha de Seguridad Estilo Credencial *@
        <div class="role-dialog-header-luxury">
            <div class="avatar-glow-shell">
                <MudAvatar Color="Color.Primary" Size="Size.Large" Class="avatar-role-shadow">
                    @Rol.Nombre[..1].ToUpper()
                </MudAvatar>
            </div>
            <div class="role-header-text-block">
                <MudText Typo="Typo.h2" Class="role-dialog-name">@Rol.Nombre</MudText>
                <div class="role-subtags d-flex align-center gap-2 mt-1">
                    <MudIcon Icon="@(Rol.EsSistema ? Icons.Material.Filled.Terminal : Icons.Material.Filled.Tune)" Size="Size.Small" Color="Color.Tertiary" />
                    <MudText Typo="Typo.caption" Class="fw-bold font-mono text-tertiary">
                        JURISDICCIÓN: @(Rol.EsSistema ? "SISTEMA BASE" : "PERSONALIZADO")
                    </MudText>
                </div>
            </div>
        </div>

        <MudDivider Class="my-5" />

        @* Celdas de Parámetros de Configuración del Rol *@
        <MudGrid Class="info-cards-grid">
            <MudItem xs="12">
                <div class="role-info-box border-left-primary">
                    <span class="role-box-label">Descripción Operativa</span>
                    <span class="role-box-value pre-wrap text-sm text-secondary">
                        @(string.IsNullOrWhiteSpace(Rol.Descripcion) ? "Sin especificaciones complementarias." : Rol.Descripcion)
                    </span>
                </div>
            </MudItem>

            <MudItem xs="12" sm="6" Class="info-cell">
                <div class="role-info-box bg-dashed-cell">
                    <span class="role-box-label">Estado de Control</span>
                    <div class="mt-1">
                        <MudChip T="string" Size="Size.Small" Color="@(Rol.Activo ? Color.Success : Color.Error)" Variant="Variant.Filled" Class="fw-bold table-chip-rounded">
                            @(Rol.Activo ? "Habilitado" : "Deshabilitado")
                        </MudChip>
                    </div>
                </div>
            </MudItem>

            <MudItem xs="12" sm="6" Class="info-cell">
                <div class="role-info-box bg-dashed-cell">
                    <span class="role-box-label">Fecha de Alta del Rol</span>
                    <span class="role-box-value text-xs text-muted mt-2">@Rol.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</span>
                </div>
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Default" OnClick="Cerrar" Class="text-none px-5 rounded-lg shadow-none">
            Cerrar Ficha
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public RolResponseDto Rol { get; set; } = new();

    private void Cerrar() => MudDialog.Close();
}