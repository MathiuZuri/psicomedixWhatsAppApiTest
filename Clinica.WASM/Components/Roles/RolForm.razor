<EditForm Model="@Model" OnValidSubmit="GuardarAsync">
    <DataAnnotationsValidator />

    <div class="role-form-wrapper">
        <MudGrid>
            <MudItem xs="12">
                <MudTextField @bind-Value="Model.Nombre"
                              Label="Identificador del Rol de Seguridad"
                              Variant="Variant.Outlined"
                              For="@(() => Model.Nombre)"
                              Disabled="@IsProcessing"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.AdminPanelSettings"
                              AdornmentColor="Color.Primary" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="Model.Descripcion"
                              Label="Descripción y Alcance Operativo"
                              Variant="Variant.Outlined"
                              For="@(() => Model.Descripcion)"
                              Lines="2"
                              Disabled="@IsProcessing" />
            </MudItem>
        </MudGrid>
    </div>

    <div class="form-actions-bar">
        <MudButton Variant="Variant.Text"
                   Color="Color.Default"
                   OnClick="OnCancel"
                   Disabled="@IsProcessing"
                   Class="text-none px-5">
            Cancelar
        </MudButton>
        <MudButton ButtonType="ButtonType.Submit"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   Disabled="@IsProcessing"
                   Class="text-none px-6 rounded-lg shadow-sm">
            @if (IsProcessing)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <span>Creando...</span>
            }
            else
            {
                <span>Crear rol</span>
            }
        </MudButton>
    </div>
</EditForm>

@code {
    [Parameter] public CrearRolDto Model { get; set; } = new();
    [Parameter] public bool IsProcessing { get; set; }
    [Parameter] public EventCallback OnSave { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private async Task GuardarAsync()
    {
        await OnSave.InvokeAsync();
    }
}